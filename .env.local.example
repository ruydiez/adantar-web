# Sanity CMS — obtén estos valores en sanity.io/manage después de crear el proyecto
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production

# Token de lectura para ISR (revalidación) — opcional pero recomendado
SANITY_API_TOKEN=your_token_here

# Resend (formulario de contacto) — obtén tu API key en resend.com
# Sin esta clave el formulario no enviará emails (solo loguea en desarrollo)
RESEND_API_KEY=your_resend_api_key_here
